@inherits LayoutComponentBase
@using Microsoft.Extensions.Options
@using MovieReviewApp.Models
@using MovieReviewApp.Components.Partials
@inject IOptions<AppSettings> AppSettings
@inject NavigationManager Navigation
@inject SecretsManager SecretsManager
@inject ThemeService ThemeService


<!-- BOTTOM NAVIGATION BAR - Mobile only -->
<nav class="bottom-nav">
    <a href="" class="bottom-nav-item @(IsCurrentPage("/") ? "active" : "")">
        <span class="nav-icon">🏠</span>
        <span>Home</span>
    </a>
    <a href="history" class="bottom-nav-item @(IsCurrentPage("/history") ? "active" : "")">
        <span class="nav-icon">📚</span>
        <span>History</span>
    </a>
    <a href="present" class="bottom-nav-item present-nav-item @(IsCurrentPage("/present") ? "active" : "")">
        <span class="nav-icon">🎬</span>
        <span>Present</span>
    </a>
    <a href="soundboard" class="bottom-nav-item @(IsCurrentPage("/soundboard") ? "active" : "")">
        <span class="nav-icon">🎵</span>
        <span>Sounds</span>
    </a>
    <a href="settings" class="bottom-nav-item @(IsCurrentPage("/settings") ? "active" : "")">
        <span class="nav-icon">⚙️</span>
        <span>Settings</span>
    </a>
</nav>

@if (IsFirstRunSetup)
{
    <div class="page-no-sidebar">
        @Body
    </div>
}
else
{
    <div class="page theater-ambient">
        <div class="sidebar @(AppSettings.Value.IsFamilyFriendly ? "sidebar-family" : "sidebar-general")">
            <NavMenu />
        </div>
        <main>
            <article class="content px-4">
                @Body
            </article>
        </main>
    </div>
}

@code {
    private bool IsFirstRunSetup => Navigation.Uri.Contains("/setup", StringComparison.OrdinalIgnoreCase) || SecretsManager.IsFirstRun;

    protected override async Task OnInitializedAsync()
    {
        await ThemeService.InitializeAsync();
    }

    private bool IsCurrentPage(string path)
    {
        string relativePath = Navigation.ToBaseRelativePath(Navigation.Uri);
        if (path == "/") return string.IsNullOrEmpty(relativePath);
        return relativePath.Equals(path.TrimStart('/'), StringComparison.OrdinalIgnoreCase);
    }
}
